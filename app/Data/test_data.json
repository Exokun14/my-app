    {
      "id": "act_007",
      "type": "accordion",
      "title": "Customer Service FAQs",
      "status": "published",
      "items": [
        {
          "q": "How do I handle a return without a receipt?",
          "a": "Check company policy. Most stores allow store credit or exchange with valid ID. Manager approval usually required."
        },
        {
          "q": "What if a customer wants to split payment?",
          "a": "Most POS systems allow multiple payment types. Process the first payment, then add second payment method."
        },
        {
          "q": "How to handle an angry customer?",
          "a": "Stay calm, listen actively, apologize for inconvenience, offer solutions, and escalate to manager if needed."
        }
      ]
    },
