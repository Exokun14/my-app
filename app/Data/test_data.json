    {
      "id": "act_005",
      "type": "fillblank",
      "title": "Transaction Procedures",
      "status": "published",
      "questions": [
        {
          "sentence": "For cash payments, always enter the __BLANK__ amount first.",
          "blanks": ["tendered"]
        },
        {
          "sentence": "Always obtain __BLANK__ before voiding a transaction.",
          "blanks": ["supervisor approval"]
        },
        {
          "sentence": "The __BLANK__ report should be run at the end of every shift.",
          "blanks": ["EOD"]
        }
      ]
    },
    {
      "id": "act_006",
      "type": "hotspot",
      "title": "End-of-Day Procedure",
      "status": "published",
      "checklist": [
        { "text": "Run EOD report from manager menu" },
        { "text": "Count cash drawer and verify against report" },
        { "text": "Secure cash in safe" },
        { "text": "Log out all active sessions" },
        { "text": "Power down terminals" },
        { "text": "Lock store entrance" }
      ]
    },
    {
      "id": "act_007",
      "type": "accordion",
      "title": "Customer Service FAQs",
      "status": "published",
      "items": [
        {
          "q": "How do I handle a return without a receipt?",
          "a": "Check company policy. Most stores allow store credit or exchange with valid ID. Manager approval usually required."
        },
        {
          "q": "What if a customer wants to split payment?",
          "a": "Most POS systems allow multiple payment types. Process the first payment, then add second payment method."
        },
        {
          "q": "How to handle an angry customer?",
          "a": "Stay calm, listen actively, apologize for inconvenience, offer solutions, and escalate to manager if needed."
        }
      ]
    },
    {
      "id": "act_008",
      "type": "checklist",
      "title": "Closing Shift Checklist",
      "status": "published",
      "checklist": [
        { "text": "Complete all pending transactions" },
        { "text": "Clean workstation and equipment" },
        { "text": "Restock supplies for next shift" },
        { "text": "Run end-of-shift report" },
        { "text": "Secure cash drawer" }
      ]
    }
  ],
