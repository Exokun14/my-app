                },
                "blocks": [
                  {
                    "id": "blk_301",
                    "type": "content",
                    "title": "Danger Zone",
                    "body": "The temperature danger zone is between 40°F and 140°F (4°C to 60°C). Bacteria multiply rapidly in this range. Keep cold foods cold (below 40°F) and hot foods hot (above 140°F). Food should not remain in the danger zone for more than 2 hours total."
                  },
                  {
                    "id": "blk_302",
                    "type": "content",
                    "title": "Proper Storage",
                    "body": "Store raw meat on bottom shelves to prevent cross-contamination. Keep refrigerator at 40°F or below and freezer at 0°F or below. Check temperatures daily with a calibrated thermometer. Label all items with dates."
                  },
                  {
                    "id": "blk_303",
                    "type": "media",
                    "mediaType": "video",
                    "mediaUrl": "https://www.youtube.com/watch?v=dQw4w9WgXcQ",
                    "mediaLabel": "Temperature Monitoring Guide"
                  }
                ]
              }
            },
            {
              "title": "Hand Washing",
              "type": "lesson",
              "done": false,
              "content": {
                "title": "Hand Washing",
                "type": "lesson",
                "media": {
                  "type": "none",
                  "url": ""
                },
                "blocks": [
                  {
                    "id": "blk_304",
                    "type": "content",
                    "title": "When to Wash",
                    "body": "Wash hands before starting work, after using the restroom, after touching face or hair, after handling raw food, after taking out trash, and after any activity that could contaminate hands. Hand washing is your first line of defense against foodborne illness."
                  },
                  {
                    "id": "blk_305",
                    "type": "content",
                    "title": "How to Wash",
                    "body": "Use warm water and soap. Scrub hands and forearms for at least 20 seconds. Clean under fingernails and between fingers. Rinse thoroughly and dry with single-use paper towel. Use paper towel to turn off faucet."
                  }
                ]
              }
            },
